<Styles xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Button.frutiger">
        <Setter Property="Background" Value="{DynamicResource GlossyGreen}"/>
        <Setter Property="Foreground" Value="#1B5E20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="Padding" Value="20,12"/>
    </Style>

    <Style Selector="Button.frutiger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource GlossyBlue}"/>
    </Style>

    <Style Selector="Button.frutigerBlue">
        <Setter Property="Background" Value="{DynamicResource GlossyBlue}"/>
        <Setter Property="Foreground" Value="#01579B"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="Padding" Value="20,12"/>
    </Style>

    <Style Selector="Button.frutigerCard">
        <Setter Property="Background" Value="{DynamicResource GlossyWhite}"/>
        <Setter Property="Foreground" Value="#388E3C"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="15,10"/>
    </Style>

    <Style Selector="Border.frutigerCard">
        <Setter Property="Background" Value="{DynamicResource GlossyWhite}"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="Padding" Value="20"/>
    </Style>

    <Style Selector="TextBox.frutiger">
        <Setter Property="Background" Value="#F5F9F5"/>
        <Setter Property="Foreground" Value="#2E7D32"/>
        <Setter Property="BorderBrush" Value="#A5D6A7"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="FontSize" Value="15"/>
    </Style>

    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- Dark Theme Styles -->
    <Style Selector="Border.dark">
        <Setter Property="Background" Value="{DynamicResource DarkGlossyCard}"/>
    </Style>

    <Style Selector="TextBlock.dark">
        <Setter Property="Foreground" Value="{DynamicResource DarkTextPrimaryBrush}"/>
    </Style>

    <Style Selector="TextBlock.darkLabel">
        <Setter Property="Foreground" Value="{DynamicResource DarkTextSecondaryBrush}"/>
    </Style>

    <Style Selector="Grid.dark">
        <Setter Property="Background" Value="{DynamicResource DarkPageBackground}"/>
    </Style>

    <Style Selector="Border.darkCard">
        <Setter Property="Background" Value="{DynamicResource DarkGlossyCard}"/>
    </Style>

    <Style Selector="Border.darkBorder">
        <Setter Property="Background" Value="{DynamicResource DarkSurfaceBrush}"/>
    </Style>

    <Style Selector="Button.dark">
        <Setter Property="Background" Value="{DynamicResource DarkGlossyGreen}"/>
        <Setter Property="Foreground" Value="{DynamicResource DarkTextPrimaryBrush}"/>
    </Style>

    <Style Selector="UserControl.dark">
        <Setter Property="Background" Value="{DynamicResource DarkPageBackground}"/>
    </Style>

    <Style Selector="ToggleSwitch.dark">
        <Setter Property="OnContent" Value="Wł"/>
        <Setter Property="OffContent" Value="Wył"/>
    </Style>

</Styles>
