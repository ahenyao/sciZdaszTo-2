    <UserControl xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:vm="using:ZdaszToApp.ViewModels"
                 mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="800"
                 Background="#363636"
                 x:Class="ZdaszToApp.Views.LoginView">
        
        <UserControl.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceInclude Source="avares://ZdaszToApp/Assets/Fonts/Fonts.axaml"/>
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </UserControl.Resources>
        
        <Design.DataContext>
            <vm:LoginViewModel />
        </Design.DataContext>
        
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>     <!--Nagłówek - nazwa aplikacji    -->
                <RowDefinition Height="*"/>     <!-- Logo   -->
                <RowDefinition Height="Auto"/>  <!-- Hasło  -->
                <RowDefinition Height="Auto"/>  <!-- Login  -->
                <RowDefinition Height="Auto"/>  <!-- Przycisk "zaloguj" i "załóż konto" -->
                <RowDefinition Height="Auto"/>  <!-- Utwórz konto   -->
                
                
            </Grid.RowDefinitions>
            
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">
            <Border Background="#878787"
                    CornerRadius="10"
                    Padding="10">
                
                <TextBlock Text="ZdaszTo!"     
                           Foreground="#363636"
                           FontFamily="{StaticResource JerseyFont}"
                           FontSize="60"/>   
            </Border>
        </StackPanel>
        
       <Image Grid.Row="1"
              Source="../Assets/avalonia-logo.ico"
              Stretch="Uniform"/>
            
        
        <Border Grid.Row="2" Background="#5E5E5E" CornerRadius="20" Margin="50,20,50,0">
        <StackPanel>
            
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="5" Margin="0,20,0,20">
                <Border Background="#878787" Padding="10" CornerRadius="5">
                    
                    <StackPanel Spacing="10">
                        <Border
                            Background="#D3D3D3"
                            CornerRadius="10">
                            
                            <TextBlock Text="Login"
                                       FontSize="30"
                                       FontFamily="{StaticResource JerseyFont}"
                                       Foreground="#363636"
                                       Margin="10,0,10,0"/>
                        </Border>
                        
                        <TextBox
                           
                            Width="200" 
                            Watermark="Wpisz login"/>
                        </StackPanel>
                </Border>
            </StackPanel>
        
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="5" Margin="0,20,0,20">
                <Border Background="#878787" Padding="10" CornerRadius="5">
                    <StackPanel Spacing="10">
                        
                        <Border
                            Background="#D3D3D3"
                            CornerRadius="10">
                            <TextBlock Text="Hasło" 
                                   FontSize="30"
                                   Foreground="#363636"
                                   FontFamily="{StaticResource JerseyFont}"
                                   Margin="10,0,10,0"/>
                            
                        </Border>
                        <TextBox Width="200" 
                                 PasswordChar="*" 
                                 Watermark="Wpisz hasło"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            
        </StackPanel>
        </Border>
        
        <Border Grid.Row="4"
                Background="#878787"
                CornerRadius="10"
                Margin="70,20,70,20">
                
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="5">
                <Button Name="LogButton"
                    Content="Zaloguj" 
                    FontSize="50"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,20"
                    CornerRadius="10"
                    Foreground="#D3D3D3"
                    Background="Red"
                    FontFamily="{StaticResource JerseyFont}"/>
            </StackPanel>
        </Border>
       
       <Border Grid.Row="5"
               Background="#878787"
               CornerRadius="10"
               Margin="80,10,80,30">
           
           <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="5">
               <Button Name="CreateAccount" 
                               Content="Utwórz konto"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,20"
                               CornerRadius="10"
                               Foreground="#D3D3D3"
                               Background="Red"
                               FontFamily="{StaticResource JerseyFont}"/>
           </StackPanel>
                </Border>
        </Grid>
            </UserControl>
