    <UserControl xmlns="https://github.com/avaloniaui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
                  Background="#363636"
                  x:Class="ZdaszToApp.Views.LoginView">
         
        <UserControl.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceInclude Source="avares://ZdaszToApp/Assets/Fonts/Fonts.axaml"/>
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </UserControl.Resources>

        <Grid>
            <Grid IsVisible="{Binding IsLoading}">
                <Border Background="#CC000000"/>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                    <Border Background="#878787" CornerRadius="50" Width="80" Height="80">
                        <Ellipse x:Name="Spinner" Width="60" Height="60" Stroke="#D3D3D3" StrokeThickness="6" 
                                 StrokeDashArray="1,4" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Border>
                    <TextBlock Text="Logowanie..." 
                               Foreground="White" 
                               FontFamily="{StaticResource JerseyFont}"
                               FontSize="30" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid IsVisible="{Binding !IsLoading}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        
            <ScrollViewer>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10">
            
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">
            <Border Background="#878787"
                    CornerRadius="10"
                    Padding="10">
                
                <TextBlock Text="ZdaszTo!"     
                           Foreground="#363636"
                           FontFamily="{StaticResource JerseyFont}"
                           FontSize="60"/>   
            </Border>
        </StackPanel>
        
        <Image Source="../Assets/avalonia-logo.ico"
               Stretch="Uniform"
               HorizontalAlignment="Center"/>
            
        
        <Border Background="#5E5E5E" CornerRadius="20" Margin="20,20,20,0">
        <StackPanel>
            
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="5" Margin="0,10,0,10">
                <TextBlock Text="{Binding Message}" 
                           Foreground="#D3D3D3" 
                           FontFamily="{StaticResource JerseyFont}"
                           FontSize="20"
                           Margin="0,10,0,0" 
                           HorizontalAlignment="Center"/>
                
                <Border Background="#878787" Padding="10" CornerRadius="5">
                    
                    
                    <StackPanel Spacing="10">
                        <Border
                            Background="#D3D3D3"
                            CornerRadius="10">
                            
                            <TextBlock Text="Login"
                                       FontSize="30"
                                       FontFamily="{StaticResource JerseyFont}"
                                       Foreground="#363636"
                                       Margin="10,0,10,0"/>
                        </Border>
                        
                        <TextBox
                            Text="{Binding Username, Mode=TwoWay}"
                            Width="200" 
                            Watermark="{Binding Error_login}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="5" Margin="0,20,0,20">
                <Border Background="#878787" Padding="10" CornerRadius="5">
                    <StackPanel Spacing="10">
                        
                        <Border
                            Background="#D3D3D3"
                            CornerRadius="10">
                            <TextBlock Text="Hasło" 
                                   FontSize="30"
                                   Foreground="#363636"
                                   FontFamily="{StaticResource JerseyFont}"
                                   Margin="10,0,10,0"/>
                        
                        </Border>
                        <TextBox 
                            Text="{Binding Password, Mode=TwoWay}"
                            Width="200" 
                            PasswordChar="*" 
                            Watermark="{Binding Error_password}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            
        </StackPanel>
        </Border>
        
        <Border Background="#878787"
                CornerRadius="10"
                Margin="70,20,70,20">
                
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="5">
                <Button Name="LogButton"
                    Content="Zaloguj" 
                    FontSize="50"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,20"
                    CornerRadius="10"
                    Foreground="#D3D3D3"
                    Background="Red"
                    FontFamily="{StaticResource JerseyFont}"
                    Command="{Binding LoginCommand}"/>
                
            </StackPanel>
        </Border>
       
        <Border Background="#878787"
                CornerRadius="10"
                Margin="80,10,80,30">
            
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="5">
                 <Button Name="CreateAccount" 
                         Content="Utwórz konto"
                         FontSize="30"
                         FontWeight="Bold"
                         HorizontalAlignment="Center"
                         Margin="0,20,0,20"
                         CornerRadius="10"
                         Foreground="#D3D3D3"
                         Background="Red"
                         FontFamily="{StaticResource JerseyFont}"
                         Command="{Binding CreateAccountCommand}"/>
            </StackPanel>
                 </Border>
        </StackPanel>
        </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
