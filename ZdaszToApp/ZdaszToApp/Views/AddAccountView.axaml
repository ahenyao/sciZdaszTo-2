<UserControl xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:vm="using:ZdaszToApp.ViewModels"
              mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="800"
              x:Class="ZdaszToApp.Views.AddAccountView">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://ZdaszToApp/Assets/Fonts/Fonts.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Design.DataContext>
        <vm:AddAccountViewModel />
    </Design.DataContext>
    
    <Grid>
        <Grid IsVisible="{Binding IsLoading}">
            <Border Background="#60000000"/>
            <Border Background="#F5F9F5" CornerRadius="20" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center" BoxShadow="0 8 25 #33000000">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                    <Border Background="#00BCD4" CornerRadius="50" Width="80" Height="80">
                        <Ellipse x:Name="Spinner" Width="60" Height="60" Stroke="White" StrokeThickness="6" 
                                 StrokeDashArray="1,4" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Border>
                    <TextBlock Text="Tworzenie konta..." 
                               Foreground="#006064" 
                               FontFamily="{StaticResource JerseyFont}"
                               FontSize="22" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding !IsLoading}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" x:Name="MainGrid">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#E8F5E9" Offset="0"/>
                    <GradientStop Color="#C8E6C9" Offset="0.5"/>
                    <GradientStop Color="#A5D6A7" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
        
        <ScrollViewer>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10">
            <Button Content="← Wróć"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="10,10,0,0"
                    FontSize="18"
                    Background="Transparent"
                    Foreground="#558B2F"
                    FontFamily="{StaticResource JerseyFont}"
                    Command="{Binding GoBackCommand}"/>
        
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">
                <Border Background="White"
                        CornerRadius="15"
                        Padding="20,12"
                        BoxShadow="0 4 12 #1A000000">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Background="#00BCD4" CornerRadius="8" Width="40" Height="40" Margin="0,0,10,0" VerticalAlignment="Center">
                            <TextBlock Text="✓" FontSize="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="ZdaszTo!"
                                   Foreground="#006064"
                                   FontFamily="{StaticResource JerseyFont}"
                                   FontSize="42"
                                   VerticalAlignment="Center"/>    
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <Border Background="#20FFFFFF" CornerRadius="15" Width="280" Margin="0,10,0,0" x:Name="FormBorder">
                <StackPanel>
                    <Image Source="../Assets/zdaszto-logo.ico"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           Width="60"
                           Height="60"
                           Margin="0,15,0,10"/>
            
                    <Border Background="White" CornerRadius="12" Margin="15,5,15,15" BoxShadow="0 2 8 #14000000" x:Name="InputBorder">
                    <StackPanel Spacing="12" Margin="0,12,0,12">
                        <StackPanel Spacing="5">
                            <Border Background="#00BCD4" CornerRadius="8" Padding="10,4" HorizontalAlignment="Left" Margin="10,0,10,0">
                                <TextBlock Text="E-mail"
                                           FontSize="14"
                                           FontFamily="{StaticResource JerseyFont}"
                                           Foreground="White"/>
                            </Border>
                            
                            <TextBox Width="200" 
                                     Text="{Binding Email, Mode=TwoWay}"
                                     Watermark="Wpisz adres e-mail"
                                     Margin="10,0,10,0"/>
                        </StackPanel>
            
                        <StackPanel Spacing="5">
                            <Border Background="#8BC34A" CornerRadius="8" Padding="10,4" HorizontalAlignment="Left" Margin="10,0,10,0">
                                <TextBlock Text="Login" 
                                           FontSize="14"
                                           Foreground="White"
                                           FontFamily="{StaticResource JerseyFont}"/>
                            </Border>
                            <TextBox Width="200" 
                                     Text="{Binding Username, Mode=TwoWay}"
                                     Watermark="Wpisz login"
                                     Margin="10,0,10,0"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="5">
                            <Border Background="#03A9F4" CornerRadius="8" Padding="10,4" HorizontalAlignment="Left" Margin="10,0,10,0">
                                <TextBlock Text="Hasło" 
                                           FontSize="14"
                                           Foreground="White"
                                           FontFamily="{StaticResource JerseyFont}"/>
                            </Border>
                            <TextBox Text="{Binding Password, Mode=TwoWay}"
                                     PasswordChar="*" 
                                     Width="200"
                                     Margin="10,0,10,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                </StackPanel>
            </Border>
            
            <Border Background="#00BCD4"
                    CornerRadius="15"
                    Margin="40,20,40,40"
                    Padding="5">
                <Border Background="#0097A7" CornerRadius="12">
                    <Button Content="Załóż konto" 
                        FontSize="22"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,10"
                        CornerRadius="10"
                        Foreground="White"
                        Background="Transparent"
                        FontFamily="{StaticResource JerseyFont}"
                        Command="{Binding SignupCommand}"/>
                </Border>
            </Border>
        </StackPanel>
        </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
