<UserControl xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:vm="using:ZdaszToApp.ViewModels"
              mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="720"
              x:Class="ZdaszToApp.Views.MenuView">
              
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://ZdaszToApp/Assets/Fonts/Fonts.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Design.DataContext>
        <vm:AddAccountViewModel />
    </Design.DataContext>
    
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" x:Name="MainGrid">
        
        <Grid.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#E8F5E9" Offset="0"/>
                <GradientStop Color="#C8E6C9" Offset="0.5"/>
                <GradientStop Color="#A5D6A7" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <Border Background="#20FFFFFF"
                Margin="20,20,20,20"
                CornerRadius="25"
                x:Name="CardBorder">
            
            <ScrollViewer>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">
                    
                    <!-- Header -->
                    <Border Background="#8BC34A" CornerRadius="10" Padding="15" Margin="0,15,0,25">
                        <TextBlock Text="ZdaszTo!" FontSize="26" FontWeight="Bold" Foreground="White"
                                   FontFamily="{StaticResource JerseyFont}" HorizontalAlignment="Center" TextAlignment="Center"/>
                    </Border>
                    
                    <!-- Menu Buttons -->
                    <StackPanel Spacing="15">
                        
                        <!-- INF.02 & INF.03 Row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- INF.02 -->
                            <Border Grid.Column="0" CornerRadius="12" Margin="5" Padding="25">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                        <GradientStop Color="#FFFFFF" Offset="0"/>
                                        <GradientStop Color="#E3F2FD" Offset="0.5"/>
                                        <GradientStop Color="#B3E5FC" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Button Background="Transparent" Click="OnInf02Click" Padding="0" HorizontalContentAlignment="Center">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Background="#8BC34A" CornerRadius="35" Width="70" Height="70" Margin="0,0,0,10" HorizontalAlignment="Center">
                                            <Image Source="../Assets/inf02.png" Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="INF.02" TextAlignment="Center" Foreground="#2E7D32"
                                                   FontFamily="{StaticResource JerseyFont}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Border>

                            <!-- INF.03 -->
                            <Border Grid.Column="1" CornerRadius="12" Margin="5" Padding="25">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                        <GradientStop Color="#FFFFFF" Offset="0"/>
                                        <GradientStop Color="#E3F2FD" Offset="0.5"/>
                                        <GradientStop Color="#B3E5FC" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Button Background="Transparent" Click="OnInf03Click" Padding="0" HorizontalContentAlignment="Center">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Background="#03A9F4" CornerRadius="35" Width="70" Height="70" Margin="0,0,0,10" HorizontalAlignment="Center">
                                            <Image Source="../Assets/inf03.png" Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="INF.03" TextAlignment="Center" Foreground="#2E7D32"
                                                   FontFamily="{StaticResource JerseyFont}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Border>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                        <!-- INF.04 - Centered -->
                        <Border Grid.Column="1" CornerRadius="12" Margin="5" Padding="25">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#FFFFFF" Offset="0"/>
                                    <GradientStop Color="#E3F2FD" Offset="0.5"/>
                                    <GradientStop Color="#B3E5FC" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Button Background="Transparent" Click="OnInf04Click" Padding="0" HorizontalContentAlignment="Center">
                                <StackPanel HorizontalAlignment="Center"> 
                                    <Border Background="#00BCD4" CornerRadius="35" Width="70" Height="70" Margin="0,0,0,10" HorizontalAlignment="Center">
                                        <Image Source="../Assets/inf04.png" Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="INF.04" TextAlignment="Center" Foreground="#2E7D32"
                                               FontFamily="{StaticResource JerseyFont}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Border>
                    </Grid>
                        <!-- Zakupy & Ranking Row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Zakupy -->
                            <!-- <Border Grid.Column="0" Background="#8BC34A"  -->
                            <!--         CornerRadius="12" Margin="5" Padding="20"> -->
                            <!--     <Button Background="Transparent" Padding="0"> -->
                            <!--         <StackPanel HorizontalAlignment="Center"> -->
                            <!--             <Border Background="#20FFFFFF" CornerRadius="35" Width="55" Height="55" Margin="0,0,0,8"> -->
                            <!--                 <Image Source="../Assets/shop.ico" Width="28" Height="28" Stretch="Uniform"/> -->
                            <!--             </Border> -->
                            <!--             <TextBlock Text="Zakupy" FontSize="16" Foreground="White"  -->
                            <!--                        FontFamily="{StaticResource JerseyFont}" FontWeight="Bold" HorizontalAlignment="Center"/> -->
                            <!--         </StackPanel> -->
                            <!--     </Button> -->
                            <!-- </Border> -->

                            <!-- Ranking -->
                            <Border Background="#03A9F4"
                                    CornerRadius="12" Margin="5" Padding="20">
                                    <Button Background="Transparent" Padding="0" Click="OnRankingClick" HorizontalAlignment="Stretch">
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Background="#20FFFFFF" CornerRadius="35" Width="55" Height="55" Margin="0,0,0,8" HorizontalAlignment="Center" >
                                                <Image Source="../Assets/ranking.ico" Width="28" Height="28" Stretch="Uniform" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Ranking" FontSize="16" Foreground="White" 
                                                       FontFamily="{StaticResource JerseyFont}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- Footer -->
                    <Border Background="White" CornerRadius="10" Padding="12" Margin="0,25,0,0" Opacity="0.9">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="★" FontSize="20" Foreground="#F57F17" VerticalAlignment="Center"/>
                            <TextBlock Text=" ZdaszToApp v1.0 " FontSize="16" Foreground="#558B2F" 
                                       FontFamily="{StaticResource JerseyFont}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>